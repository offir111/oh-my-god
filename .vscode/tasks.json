{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "debate-app: הפעלה (שרת + דפדפן)",
      "type": "shell",
      "command": "npm run dev:full",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "debate-dev",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+https?://"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
