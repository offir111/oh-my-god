# Server port
PORT=3001

# Required for AI debates, Bible search, מאגר ידע — Groq API
# Keys: https://console.groq.com/keys — copy this file to .env and set the value.
GROQ_API_KEY=

# Optional: chat model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: fallback if primary fails (default: llama-3.1-8b-instant)
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Set to 1 so API errors include a short Groq detail (development only).
# DEBUG_GROQ=


# Optional: comma-separated origins for production CORS
# ALLOWED_ORIGINS=https://your-app.com

# Site admin login (display username OMG). Exactly 8 characters — required in production (Railway etc.).
# In local dev, if unset, the server uses a temporary password and prints it in the console (see server logs).
OMG_ADMIN_PASSWORD=

# Optional: separate secret for admin session HMAC (defaults to OMG_ADMIN_PASSWORD)
# OMG_ADMIN_SESSION_SECRET=
